# Elwood Configuration Example
# Copy this to config.yaml and customize

# Directory for persistent state (conversation history, etc.)
# Default: /var/lib/assistant
state_dir: /var/lib/assistant

# Directory containing SOUL.md, AGENTS.md, etc.
# Default: /var/lib/assistant/workspace
workspace_dir: /var/lib/assistant/workspace

# Telegram chat configurations
# Find your chat ID by messaging @userinfobot on Telegram
# Each chat has an ID and an optional session name for persistent conversation.
# Omit session for isolated/ephemeral mode (no conversation history).
telegram_chats:
  - id: 123456789
    session: main       # persistent conversation (omit for isolated/ephemeral)
    # agent:                             # per-chat agent overrides (default: use global settings)
    #   model: claude-haiku-4-20250414
    #   thinking:
    #     type: adaptive
    #     effort: low
    #   max_iterations: 10
    #   max_tokens: 8192
    #   cache_ttl: 5m

# Agent settings (model, thinking, iteration limit)
agent:
  # Claude model to use
  # Default: claude-sonnet-4-20250514
  model: claude-sonnet-4-20250514

  # Extended thinking configuration
  # Controls Claude's internal reasoning before responding.
  # Default: off
  #
  # Structured format only:
  #   thinking:
  #     type: off
  #
  #   thinking:
  #     type: adaptive
  #     effort: medium          # low | medium | high (default: medium)
  #
  #   thinking:
  #     type: fixed
  #     budget_tokens: 4096      # explicit budget_tokens value
  thinking:
    type: off

  # Maximum tokens for API responses
  # Since billing is per actual token used, a high limit costs nothing extra.
  # Default: 16384
  max_tokens: 16384

  # Maximum agent loop iterations per turn (prevents infinite tool-use loops)
  # Default: 20
  max_iterations: 20

  # Prompt cache TTL
  # Controls the cache lifetime for prompt caching. Longer TTLs cost more for
  # cache writes but help if requests are spaced more than 5 minutes apart.
  # Values: "5m" (default, 1.25x write cost) or "1h" (2x write cost)
  # cache_ttl: 5m

# Delegate sub-agent configuration for delegate_task.
# The main agent can further override model, thinking, and max_iterations
# per-call via tool parameters.
#
# Layering precedence (highest wins):
#   tool parameters > extra_agents preset > default_agent > delegate defaults > parent agent
# delegate:
#   default_agent:                # overrides parent agent settings (omit to inherit)
#     model: claude-haiku-4-20250414
#     thinking:
#       type: off
#     max_iterations: 10          # default: 10
#     max_tokens: 8192
#     cache_ttl: 5m
#   extra_agents:                 # named presets selectable via delegate_task's 'agent' parameter
#     fast:
#       model: claude-haiku-4-20250414
#       thinking:
#         type: off
#       max_tokens: 4096
#     deep:
#       model: claude-sonnet-4-20250514
#       thinking:
#         type: adaptive
#         effort: high
#       max_tokens: 32768
#   allowed_models:               # models the main agent can choose from
#     - claude-haiku-4-20250414
#     - claude-sonnet-4-20250514

# Maximum image dimension (pixels) for images sent to the Claude API.
# Images exceeding this are resized (preserving aspect ratio) before sending.
# Set to null to disable resizing and send original images.
# Default: 1568 (Claude's native processing resolution)
max_image_dimension: 1568

# Send notification messages when the agent uses tools (e.g. "🔧 Using bash")
# Default: true
tool_use_messages: true

# Tool search: null | [] | [tool1, ...]
# Uses Anthropic's server-side tool search for on-demand tool discovery.
# All tools are sent in every request (enabling prompt caching), with most
# marked for deferred loading. The model searches and activates tools as needed.
#   null/omitted    - disabled (all tool schemas sent non-deferred)
#   []              - enabled (all tools deferred, model searches for them)
#   [tool1, tool2]  - enabled, but listed tools are never deferred
#
# The list is optional. It provides a minor latency optimization for
# frequently-used tools (avoids the server-side search round-trip).
# tool_search: null

# System prompt configuration
# A list of prompt inputs assembled into the system prompt.
# Default (when omitted): [{ type: workspace_file, path: SOUL.md }]
#
# Supported input types:
#   - type: workspace_file    # read file from workspace_dir
#     path: SOUL.md
#   - type: text             # inline text
#     content: "Additional context"
#
# system_prompt:
#   - type: workspace_file
#     path: SOUL.md
#   - type: text
#     content: "Additional instructions"

# Context compaction settings
# When conversation history exceeds the token threshold, older messages
# are summarized using a fast model to stay within context limits.
compaction:
  token_threshold: 50000             # default: 50000
  model: claude-3-5-haiku-20241022  # default: claude-3-5-haiku-20241022
  # Strategy for splitting messages into compact vs keep regions.
  # { keep_last_turns: N } — keep last N turns verbatim, compact the rest (default: 10)
  # { keep_last_fraction: F } — keep ~(F * token_threshold) tokens from the end
  # strategy: { keep_last_turns: 10 }
  # Custom compaction prompt (conversation text is appended automatically).
  # Default: built-in structured prompt with User Profile/Projects & Goals/
  # Key Facts & Decisions/Progress/Open Threads sections.
  # prompt: "Summarize the conversation concisely, preserving key facts and decisions."

# Tool result pruning settings
# When the Anthropic cache TTL expires, tool results before the horizon are
# soft-pruned: head and tail are kept with an indicator in between. Recent
# turns are protected from pruning entirely.
pruning:
  head_chars: 500       # characters to keep from start of pruned content (default: 500)
  tail_chars: 500       # characters to keep from end of pruned content (default: 500)
  keep_turns: 3         # recent turns protected from pruning (default: 3)
  thinking_keep_turns: 1  # keep thinking blocks for last N turns, independent of keep_turns (default: 1, null = keep all)
  tool_input_threshold: 5000  # prune tool inputs exceeding this many chars (default: 5000, null = disabled)

# Built-in meta-tool: delegate_task
# Always available. Spawns a sub-agent with an isolated conversation to handle
# multi-step tasks without bloating the main context. The sub-agent has access
# to all tools except delegate_task (no recursive nesting).
# The main agent can override model, thinking, and max_iterations per-call
# via tool parameters. Configure defaults under delegate: above.

# Tool permission settings
permissions:
  default_policy: allow          # allow | ask | deny (default: allow)
  approval_timeout_seconds: 120   # seconds to wait for user approval (default: 120)
  tool_policies:                 # per-tool overrides
    run_command: ask            # NOTE: "ask" requires an interactive approval
                                # channel (Telegram). Webhook-triggered runs
                                # deny "ask" tools — use "allow" for tools
                                # that webhooks need.
  dangerous_patterns:            # regex patterns — matched commands are denied
    - "\\brm\\b"               # block rm, but...
    - "\\bsudo\\b"
  safe_patterns:                 # regex patterns — override dangerous_patterns
    - "^rm -i\\b"              # ...allow interactive rm

# MCP (Model Context Protocol) server configurations
# Each key becomes the server name used to namespace its tools.
mcp_servers:
  my-server:
    command: npx                    # command to run (required)
    args:                           # command arguments
      - "-y"
      - "@example/mcp-server"
    env:                            # environment variables
      API_KEY: "secret"
    startup_delay: 1000              # ms to wait after spawn (default: 0)

# Webhook server configuration
# Exposes HTTP endpoints that trigger agent conversations.
# Built-in endpoints (no auth required):
#   GET /health   - health check (returns {"status":"ok"})
#   GET /metrics  - Prometheus metrics endpoint
webhook:
  enabled: false                # default: false
  port: 8080                    # default: 8080
  secret: "s3cret"               # required header X-Webhook-Secret (or set WEBHOOK_SECRET env var)
  endpoints:
    - name: deploy              # route: POST /webhook/deploy (required)
      prompt:                   # prompt inputs (assembled and rendered with {{.field}} placeholders)
        - type: text
          content: "Deploy event: {{.repo}} {{.branch}}"
      # session: "123456789"    # session name for persistent conversation (default: null = isolated)
      # agent:                            # per-endpoint agent overrides (default: use global settings)
      #   model: claude-haiku-4-20250414
      #   thinking:
      #     type: adaptive
      #     effort: low
      #   max_iterations: 5
      #   max_tokens: 8192
      #   cache_ttl: 5m
      delivery_target:                      # where to send responses (default: telegram_broadcast)
        type: telegram_broadcast          # broadcast to all telegram_chats
      # delivery_target:
      #   type: telegram
      #   chat_ids: [123456789]           # send to specific chat(s)
      # delivery_target:
      #   type: log_only                  # log only, no notification
      suppress_if_contains: "no action needed"  # suppress notification if response contains this

# Environment variables (not set in this file):
#   TELEGRAM_BOT_TOKEN   - Telegram bot token (required)
#   ANTHROPIC_API_KEY    - Anthropic API key (required)
#   WEBHOOK_SECRET       - Webhook secret (optional, overrides secret above)
